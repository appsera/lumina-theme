{#
=====================================================================
  LUMINA — Footer  (components/footer/footer.twig)
  • Newsletter, trust badges, social, dynamic Salla footer menus.
  • Respects footer_is_dark merchant setting (class on <body>).
=====================================================================
#}
<footer class="lumina-footer mt-auto">

    {# ---------- Trust strip ---------- #}
    {% if theme.settings.get('show_trust_badges', true) %}
    <div class="lumina-trust border-y border-black/5 dark:border-white/5">
        <div class="lumina-container grid grid-cols-2 md:grid-cols-4 gap-6 py-8">
            {% set badges = [
                {icon:'sicon-truck-fast', title: trans('footer.fast_delivery','Fast Delivery'), sub: trans('footer.fast_delivery_sub','Across the kingdom')},
                {icon:'sicon-shield-check', title: trans('footer.secure_payment','Secure Payment'), sub: trans('footer.secure_payment_sub','100% protected')},
                {icon:'sicon-refresh-alt', title: trans('footer.easy_returns','Easy Returns'), sub: trans('footer.easy_returns_sub','Hassle-free')},
                {icon:'sicon-headset', title: trans('footer.support','24/7 Support'), sub: trans('footer.support_sub','Always here')}
            ] %}
            {% for b in badges %}
            <div class="flex items-center gap-3">
                <span class="lumina-trust-ico"><i class="{{ b.icon }} text-2xl" aria-hidden="true"></i></span>
                <span class="flex flex-col">
                    <strong class="text-sm font-semibold leading-tight">{{ b.title }}</strong>
                    <span class="text-xs text-[var(--color-muted)]">{{ b.sub }}</span>
                </span>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# ---------- Newsletter ---------- #}
    {% if theme.settings.get('show_newsletter', true) %}
    <div class="lumina-container py-12">
        <div class="lumina-newsletter relative overflow-hidden rounded-[var(--radius-lg)] p-8 sm:p-12 text-center">
            <h2 class="text-2xl sm:text-3xl font-bold mb-2">{{ theme.settings.get('newsletter_title', trans('footer.newsletter_title','Join the list')) }}</h2>
            <p class="text-[var(--color-muted)] mb-6 max-w-md mx-auto">{{ theme.settings.get('newsletter_sub', trans('footer.newsletter_sub','Exclusive drops & offers, straight to your inbox.')) }}</p>
            <salla-newsletter class="max-w-md mx-auto block"></salla-newsletter>
        </div>
    </div>
    {% endif %}

    {# ---------- Main footer ---------- #}
    <div class="lumina-container grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8 py-12">
        <div class="col-span-2 lg:col-span-2">
            {% if store.logo %}
                <img src="{{ store.logo }}" alt="{{ store.name }}" width="160" height="48" loading="lazy" class="h-10 w-auto mb-4 object-contain"/>
            {% else %}
                <span class="text-xl font-bold">{{ store.name }}</span>
            {% endif %}
            <p class="text-sm text-[var(--color-muted)] max-w-xs leading-relaxed">{{ store.description }}</p>

            {# Social #}
            <div class="flex items-center gap-2 mt-5">
                {% for net, url in store.social %}
                    {% if url %}
                    <a href="{{ url }}" rel="noopener" target="_blank" class="lumina-social" aria-label="{{ net }}">
                        <i class="sicon-{{ net }}" aria-hidden="true"></i>
                    </a>
                    {% endif %}
                {% endfor %}
            </div>
        </div>

        {# Dynamic merchant footer menus #}
        <salla-menu menu="footer" class="contents lumina-footer-menu"></salla-menu>
    </div>

    {# ---------- Payment methods + copyright ---------- #}
    <div class="border-t border-black/5 dark:border-white/5">
        <div class="lumina-container flex flex-col sm:flex-row items-center justify-between gap-4 py-6">
            <p class="text-xs text-[var(--color-muted)]">
                © {{ "now"|date("Y") }} {{ store.name }}. {{ trans('footer.rights','All rights reserved.') }}
            </p>
            <salla-payments-banner class="opacity-90"></salla-payments-banner>
        </div>
    </div>
</footer>
