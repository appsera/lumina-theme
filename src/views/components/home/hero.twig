{#
=====================================================================
  LUMINA — Home Hero (custom component)
  Mapped in twilight.json -> "path": "home.hero"
  Immersive, responsive, zero-CLS (image has fixed ratio + priority).
=====================================================================
#}
<section class="lumina-hero" data-reveal>
    <div class="lumina-container">
        <div class="lumina-hero-grid {{ (component.layout|default('split')) == 'centered' ? 'is-centered' : '' }}">
            <div class="lumina-hero-copy">
                {% if component.eyebrow %}
                    <span class="lumina-eyebrow">{{ component.eyebrow }}</span>
                {% endif %}
                <h1 class="lumina-hero-title">{{ (component.title|default(store.name)) }}</h1>
                {% if component.subtitle %}
                    <p class="lumina-hero-sub">{{ component.subtitle }}</p>
                {% endif %}
                <div class="lumina-hero-actions">
                    {% if component.cta_text %}
                        <a href="{{ (component.cta_url|default('#')) }}" class="lumina-btn lumina-btn-primary">
                            {{ component.cta_text }}
                        </a>
                    {% endif %}
                    {% if component.cta2_text %}
                        <a href="{{ (component.cta2_url|default('#')) }}" class="lumina-btn lumina-btn-ghost">
                            {{ component.cta2_text }}
                        </a>
                    {% endif %}
                </div>
            </div>

            {% if component.image %}
            <div class="lumina-hero-media">
                <img src="{{ component.image }}"
                     alt="{{ (component.title|default(store.name)) }}"
                     width="900" height="1000" fetchpriority="high" decoding="async"
                     class="lumina-hero-img"/>
            </div>
            {% endif %}
        </div>
    </div>
</section>
