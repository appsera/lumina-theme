{#  LUMINA — Full-width countdown CTA band (home.countdown-cta) #}
<section class="lumina-countdown-band" data-reveal
         {% if component.bg_image %}style="background-image:linear-gradient(rgba(0,0,0,.45),rgba(0,0,0,.55)),url('{{ component.bg_image }}')"{% endif %}>
  <div class="lumina-container lumina-countdown-inner">
        {% if component.eyebrow %}<span class="lumina-eyebrow" style="color:#fff">{{ component.eyebrow }}</span>{% endif %}
        <h2 class="lumina-countdown-title">{{ (component.title|default(trans('home.flash'))) }}</h2>
        {% if component.subtitle %}<p class="lumina-countdown-sub">{{ component.subtitle }}</p>{% endif %}
        {% if component.ends_at %}
            <salla-count-down date="{{ component.ends_at }}" end-text="{{ trans('home.ended') }}"
                              class="lumina-countdown lumina-countdown--lg"></salla-count-down>
        {% endif %}
        {% if component.cta_text %}
            <a href="{{ (component.cta_url|default('#')) }}" class="lumina-btn lumina-btn-primary mt-2">{{ component.cta_text }}</a>
        {% endif %}
  </div>
</section>
