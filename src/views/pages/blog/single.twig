{#  LUMINA — Single blog article (pages/blog/single.twig)  #}
{% extends "layouts.master" %}
{% block content %}
<article class="lumina-container py-8 lg:py-12">
    <header class="max-w-3xl mx-auto text-center mb-8" data-reveal>
        {% if article.category %}<span class="lumina-eyebrow">{{ article.category.name }}</span>{% endif %}
        <h1 class="lumina-listing-title">{{ article.title }}</h1>
        <p class="lumina-blog-meta mt-3">{{ article.date }} · {{ article.reading_time ?: '3' }} {{ trans('blog.min_read') }}</p>
    </header>

    {% if article.image %}
    <div class="max-w-4xl mx-auto rounded-[var(--radius-lg)] overflow-hidden mb-10" data-reveal>
        <img src="{{ article.image }}" alt="{{ article.title }}" width="1024" height="576"
             fetchpriority="high" decoding="async" class="w-full object-cover"/>
    </div>
    {% endif %}

    <div class="lumina-prose mx-auto" data-reveal>{{ article.content | raw }}</div>

    {# Share #}
    <div class="max-w-3xl mx-auto mt-10 flex items-center gap-3 border-t border-black/5 pt-6" data-reveal>
        <span class="text-sm font-semibold">{{ trans('blog.share') }}</span>
        <salla-social-share class="flex gap-2"></salla-social-share>
    </div>
</article>

{# Related comments #}
{% if store.settings.rating_enabled %}
<section class="lumina-container lumina-section">
    {% include 'partials.section-head' with {title: trans('blog.comments')} %}
    <salla-comments comamentable-id="{{ article.id }}" comamentable-type="article"></salla-comments>
</section>
{% endif %}
{% endblock %}
