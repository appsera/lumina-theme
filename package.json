{
  "name": "lumina-salla-theme",
  "version": "1.0.0",
  "description": "Lumina — a premium, conversion-first, luxury Salla Twilight theme.",
  "license": "MIT",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "production": "webpack --mode production",
    "prod": "webpack --mode production",
    "development": "webpack --mode development",
    "watch": "webpack --mode development --watch"
  },
  "author": "Lumina",
  "comments": {
    "_versions": "Versions are PINNED (no ^ ranges) on purpose. Newer majors of glob/copy-webpack-plugin/etc. are ESM-only and crash Salla's CommonJS watcher.js with ERR_REQUIRE_ESM. Do NOT loosen these. Always install with the committed pnpm-lock.yaml (pnpm install --frozen-lockfile)."
  },
  "dependencies": {
    "@babel/runtime": "7.28.6",
    "lite-youtube-embed": "0.3.2"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/plugin-transform-runtime": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@salla.sa/twilight": "2.14.467",
    "@salla.sa/twilight-components": "2.14.467",
    "@salla.sa/twilight-tailwind-theme": "2.14.467",
    "@tailwindcss/forms": "0.5.11",
    "autoprefixer": "10.5.0",
    "babel-loader": "10.1.1",
    "copy-webpack-plugin": "13.0.1",
    "css-loader": "6.11.0",
    "css-minimizer-webpack-plugin": "7.0.4",
    "glob": "10.5.0",
    "mini-css-extract-plugin": "2.10.2",
    "postcss": "8.5.15",
    "postcss-import": "16.1.1",
    "postcss-loader": "8.2.1",
    "postcss-nesting": "12.1.5",
    "postcss-preset-env": "8.5.1",
    "sass": "1.101.0",
    "sass-loader": "16.0.8",
    "tailwindcss": "3.4.19",
    "webpack": "5.107.2",
    "webpack-cli": "5.1.4"
  },
  "pnpm": {
    "overrides": {
      "glob": "10.5.0"
    }
  }
}
