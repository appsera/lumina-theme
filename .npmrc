# Lumina — pnpm configuration
# Salla's build tooling (watcher.js, twilight) is CommonJS and expects
# certain transitive deps (e.g. glob) to be resolvable. Hoist them so
# strict pnpm isolation doesn't cause "Cannot find module" / ESM errors.
shamefully-hoist=true
strict-peer-dependencies=false
auto-install-peers=true
